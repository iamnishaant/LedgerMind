# AI FinanceOS — Backend Environment Variables
# Copy this to .env and fill in your values

# ── App ──────────────────────────────────────────────────────
ENV=development
DEBUG=true

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Postgres URI for the LangGraph durable checkpointer (human-in-the-loop).
# Supabase → Project Settings → Database → Connection string (URI).
# Leave blank in dev to use an in-memory checkpointer.
DATABASE_URL=

# ── LLMs ─────────────────────────────────────────────────────
# Which provider agents reason with: 'anthropic' (default) or 'openai'
LLM_PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI (alternative)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Inngest (Phase 1+ event bus) ──────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Agent Config ──────────────────────────────────────────────
# Receipts with OCR confidence below this will require human review
OCR_CONFIDENCE_THRESHOLD=0.85

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:3000"]

# ── Automations (Phase 8: Gmail auto-ingest) ─────────────────
# Google Cloud Console → OAuth "Web application" client (Gmail API enabled,
# scope gmail.readonly). Redirect URI must EXACTLY match the console entry.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/automations/callback/gmail
FRONTEND_URL=http://localhost:3000

# ⚠️  TOKEN_ENCRYPTION_KEY — Fernet key encrypting OAuth tokens at rest.
#   Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   - BACK IT UP separately from the database: losing it makes every stored
#     token permanently undecryptable (all users must reconnect).
#   - NEVER commit the real key.
TOKEN_ENCRYPTION_KEY=

# Gmail ingest tuning: lookback window + hard cap per sync run
GMAIL_LOOKBACK_DAYS=30
SYNC_MAX_ITEMS_PER_RUN=20
